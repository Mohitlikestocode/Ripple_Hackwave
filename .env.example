# Anthropic API key — used by the Vite dev-server proxy at /api/anthropic.
# The key never reaches the browser. Copy this file to `.env.local` and fill in.
#
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — override the model. Defaults to claude-sonnet-4-5.
VITE_CLAUDE_MODEL=claude-sonnet-4-5
